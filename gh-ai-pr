#!/usr/bin/env python3
import subprocess
import sys
from pathlib import Path

def run_command(cmd, silent=False):
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return result.stdout.strip()
    except subprocess.CalledProcessError as e:
        if not silent:
            print(f"Error running command {' '.join(cmd)}: {e}", file=sys.stderr)
        return None

def get_base_branch():
    # 1. Try to get default branch from gh cli (requires remote)
    base = run_command(["gh", "repo", "view", "--json", "defaultBranchRef", "--jq", ".defaultBranchRef.name"], silent=True)
    if base:
        return base

    # 2. Try to get the remote default branch via git
    # Often 'origin/HEAD' points to the default branch
    remote_head = run_command(["git", "symbolic-ref", "refs/remotes/origin/HEAD", "--short"], silent=True)
    if remote_head:
        # remote_head will be 'origin/main', we want 'main'
        return remote_head.split('/')[-1]

    # 3. Fallback to checking local branches
    branches = run_command(["git", "branch", "--list", "main", "master"], silent=True)
    if branches:
        if "main" in branches:
            return "main"
        if "master" in branches:
            return "master"

    # 4. Final fallback
    return "main"

def get_current_branch():
    return run_command(["git", "rev-parse", "--abbrev-ref", "HEAD"])

def get_commits(base, current):
    # Get commits that are in current but not in base
    # format: %s = subject, %b = body
    cmd = ["git", "log", f"{base}..{current}", "--pretty=format:TITLE: %s%nBODY:%n%b%n---"]
    return run_command(cmd)

def find_pr_template():
    search_paths = [
        Path(".github/PULL_REQUEST_TEMPLATE.md"),
        Path(".github/pull_request_template.md"),
        Path("PULL_REQUEST_TEMPLATE.md"),
        Path("pull_request_template.md"),
        Path(".github/PULL_REQUEST_TEMPLATE/default.md")
    ]
    for path in search_paths:
        if path.exists() and path.is_file():
            return path.read_text()
    
    # Also check the directory .github/PULL_REQUEST_TEMPLATE/
    template_dir = Path(".github/PULL_REQUEST_TEMPLATE")
    if template_dir.is_dir():
        # Get the first .md file found in the directory
        for template_file in template_dir.glob("*.md"):
            return template_file.read_text()
                
    return None

def main():
    base = get_base_branch()
    current = get_current_branch()
    
    if not current:
        print("Error: Could not determine current branch.", file=sys.stderr)
        sys.exit(1)

    if current == base:
        # For local testing, if we are on base branch, just grab the last 5 commits
        commits = run_command(["git", "log", "-n", "5", "--pretty=format:TITLE: %s%nBODY:%n%b%n---"])
    else:
        commits = get_commits(base, current)
    
    if not commits:
        print(f"No commits found on branch {current} relative to {base}.", file=sys.stderr)
        sys.exit(1)

    template = find_pr_template()
    
    prompt = f"""Generate a pull request description based on the following commit history.

COMMIT HISTORY:
{commits}

"""
    if template:
        prompt += f"""PULL REQUEST TEMPLATE:
{template}

"""
    
    prompt += "Please provide a title for the pull request and a detailed description following the template if provided."
    
    print(prompt)

if __name__ == "__main__":
    main()
