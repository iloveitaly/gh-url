#!/usr/bin/env python3
import shutil
import subprocess
import sys
import re
import webbrowser

RED = "\033[31m"
RESET = "\033[0m"


def err(msg):
    print(f"{RED}{msg}{RESET}", file=sys.stderr)


def run(cmd, silent=False):
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        if not silent:
            err(result.stderr.strip())
        return None
    return result.stdout.strip()


def parse_remote_url(remote_url):
    # SSH: git@github.com:owner/repo.git
    ssh_match = re.match(r"git@([^:]+):(.+?)(?:\.git)?$", remote_url)
    if ssh_match:
        return f"{ssh_match.group(1)}/{ssh_match.group(2)}"

    # HTTPS (with optional credentials): https://user:token@github.com/owner/repo.git
    https_match = re.match(r"https?://(?:[^@]+@)?(.+?)(?:\.git)?$", remote_url)
    if https_match:
        return https_match.group(1)

    return None


def main():
    no_clip = "--no-clip" in sys.argv
    open_browser = "--open" in sys.argv
    args = [a for a in sys.argv[1:] if a not in ("--no-clip", "--open")]
    ref = args[0] if args else "HEAD"

    sha = run(["git", "rev-parse", "--verify", ref])
    if not sha:
        err(f"invalid ref: {ref}")
        sys.exit(1)

    remote_url = run(["git", "config", "--get", "remote.origin.url"])
    if not remote_url:
        err("could not determine remote.origin.url")
        sys.exit(1)

    host_and_path = parse_remote_url(remote_url)
    if not host_and_path:
        err(f"unrecognized remote URL format: {remote_url}")
        sys.exit(1)

    # Split into host and repo path (e.g. github.com/owner/repo)
    parts = host_and_path.split("/", 1)
    host = parts[0]
    repo_path = parts[1] if len(parts) > 1 else ""
    base_url = f"https://{host}/{repo_path}"

    is_branch = run(["git", "show-ref", "--verify", "--quiet", f"refs/heads/{ref}"], silent=True) is not None
    is_tag = run(["git", "show-ref", "--verify", "--quiet", f"refs/tags/{ref}"], silent=True) is not None

    if is_branch:
        url = f"{base_url}/tree/{ref}"
    elif is_tag:
        url = f"{base_url}/releases/tag/{ref}"
    else:
        url = f"{base_url}/commit/{sha}"

    print(url)
    if not no_clip:
        copy_to_clipboard(url)
    if open_browser:
        webbrowser.open(url)


def copy_to_clipboard(text):
    if shutil.which("pbcopy"):
        subprocess.run(["pbcopy"], input=text, text=True)
    elif shutil.which("xclip"):
        subprocess.run(["xclip", "-selection", "clipboard"], input=text, text=True)
    elif shutil.which("xsel"):
        subprocess.run(["xsel", "--clipboard", "--input"], input=text, text=True)


if __name__ == "__main__":
    main()
